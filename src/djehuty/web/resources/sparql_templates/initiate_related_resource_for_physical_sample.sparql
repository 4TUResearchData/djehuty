{% extends "prefixes.sparql" %}
{% block query %}
INSERT {
  GRAPH <{{state_graph}}> {
    ?sample djht:related_resources <blank:{{blank_uuid}}> .
    <blank:{{blank_uuid}}> rdf:first <physical-sample-related-resource:{{identifier_uuid}}> .
    <blank:{{blank_uuid}}> rdf:rest rdf:nil .
    <blank:{{blank_uuid}}> djht:index 0 .
  }
}
WHERE {
  GRAPH <{{state_graph}}> {
    ?container      rdf:type                  djht:PhysicalSampleContainer .
    ?container      djht:account              ?account .
    ?container      djht:draft                ?sample .

    FILTER NOT EXISTS { ?sample djht:related_resources ?related_resources . }
    FILTER (?container = <container:{{container_uuid}}>)
    FILTER (?account   = <account:{{account_uuid}}>)
  }
}
{% endblock %}
