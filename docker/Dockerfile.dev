FROM python:3.14-slim-bookworm@sha256:86f975aca15cf04a40b399eebede9aea7c82eae084d1f1a0a6ef6bcaae871a30

# INSTALL_DEV=1 includes dev dependencies (pytest, playwright, coverage, …)
# and a Playwright-compatible chromium. Used by the e2e compose override.
ARG INSTALL_DEV=0

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
       git \
       libxmlsec1-dev \
       pkg-config \
       curl \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

COPY --from=ghcr.io/astral-sh/uv:0.11.21@sha256:ff07b86af50d4d9391d9daf4ff89ce427bc544f9aae87057e69a1cc0aa369946 /uv /usr/local/bin/uv

WORKDIR /app

ENV UV_COMPILE_BYTECODE=1

# Install dependencies first (cached layer)
COPY pyproject.toml uv.lock ./
RUN --mount=type=cache,target=/root/.cache/uv \
    if [ "$INSTALL_DEV" = "1" ]; then \
        uv sync --frozen --no-install-project; \
    else \
        uv sync --frozen --no-install-project --no-dev; \
    fi

# Install the package in editable mode
# Source is bind-mounted at runtime, but we need the package structure
COPY src/ ./src/
COPY README.md ./
RUN --mount=type=cache,target=/root/.cache/uv \
    if [ "$INSTALL_DEV" = "1" ]; then \
        uv sync --frozen; \
    else \
        uv sync --frozen --no-dev; \
    fi

ENV PATH="/app/.venv/bin:$PATH"

# Install Playwright's chromium with system deps when dev tooling is enabled.
RUN if [ "$INSTALL_DEV" = "1" ]; then \
        playwright install --with-deps chromium; \
    fi

EXPOSE 8080

CMD ["sh", "-c", "exec djehuty web --initialize --config-file \"${DJEHUTY_CONFIG:-/config/djehuty/djehuty-dev-config.json}\""]
